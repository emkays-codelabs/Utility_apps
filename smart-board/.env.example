# =====================
# Backend Configuration
# =====================

# OpenAI/Euron API Key for AI Chat
# Get your API key from: https://api.euron.one
# This is used by the Express backend (server.cjs)
# Required for AI chat to work
OPENAI_API_KEY=your_api_key_here

# =====================
# Frontend Configuration
# =====================

# API Backend URL for production deployments
# Set this in Vercel environment variables when deploying
# Format: https://your-domain.ngrok-free.app/api
# Do NOT set this locally (it breaks the Vite proxy for local development)
#
# When deploying to Vercel:
#   1. Start ngrok: ngrok http 3001
#   2. Copy the URL and add /api: https://your-ngrok-url/api
#   3. Run: npx vercel env add VITE_API_URL production
#   4. Paste the URL from step 2
#
# VITE_API_URL=https://your-domain.ngrok-free.app/api
